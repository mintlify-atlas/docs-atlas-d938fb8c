  "keyFeatures": [
    "Automatic CPU frequency scaling based on battery state and system load",
    "Governor management (powersave/performance/balanced)",
    "Turbo boost control with automatic, always, or never modes",
    "Real-time CPU monitoring with temperature and usage tracking",
    "Battery charging threshold configuration for supported devices",
    "Daemon mode for persistent automatic optimizations",
    "Live mode for temporary optimizations without installation",
    "Configuration file support for custom profiles",
    "GUI interface for system monitoring and control",
    "Bluetooth power management"
  ],
  "publicApiSurface": [
    "auto-cpufreq --monitor",
